FROM python:3.12-bookworm

# Install Python requirements
COPY Scraper/requirements.txt requirements.txt
RUN pip install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright's Chromium browser plus its system dependencies in one
# step (--with-deps runs apt-get for whatever the container is missing).
RUN playwright install --with-deps chromium

# Copy scraper code
COPY Scraper Scraper

# Run FastAPI scraper service
CMD uvicorn Scraper.api:app --host 0.0.0.0 --port $PORT
